projection proj_ui_shared_imported_focus_ios {
  name "Imported Shared UI Draft"
  description "Drafted from imported UI candidates. Review and adapt before adoption."

  platform ui_shared
  realizes [
    // add capability ids
  ]
  outputs [ui_contract]

  ui_app_shell {
    brand "Imported focus ios"
    shell topbar
  }

  ui_screens {
    screen home kind flow title "Home"
    screen about kind detail title "About"
    screen add_custom_domain kind flow title "Add Custom Domain"
    screen add_search_engine kind settings title "Add Search Engine"
    screen app_color kind list title "App Color"
    screen app_font kind list title "App Font"
    screen app_image kind list title "App Image"
    screen attributed_link_text kind list title "Attributed Link Text"
    screen autocomplete_custom_url kind flow title "Autocomplete Custom Url"
    screen autocomplete_setting kind flow title "Autocomplete Setting"
    screen browser kind flow title "Browser"
    screen card_banner kind list title "Card Banner"
    screen default_browser_onboarding kind list title "Default Browser Onboarding"
    screen focus_widgets_entry kind list title "Focus Widgets Entry"
    screen get_started_onboarding kind list title "Get Started Onboarding"
    screen internal_crash_reporting_setting kind list title "Internal Crash Reporting Setting"
    screen internal_setting kind list title "Internal Setting"
    screen legacy_web kind flow title "Legacy Web"
    screen license_list kind list title "License List"
    screen onboarding kind settings title "Onboarding"
    screen onboarding_instruction_label kind list title "Onboarding Instruction Label"
    screen onboarding_preview kind list title "Onboarding Preview"
    screen onboarding_search_widget kind list title "Onboarding Search Widget"
    screen photon_action_sheet kind flow title "Photon Action Sheet"
    screen privacy_policy kind list title "Privacy Policy"
    screen safari_instruction kind flow title "Safari Instruction"
    screen search_setting kind settings title "Search Setting"
    screen search_widget kind list title "Search Widget"
    screen setting kind settings title "Setting"
    screen settings_content kind settings title "Settings Content"
    screen share_tracker kind flow title "Share Tracker"
    screen sheet_modal kind flow title "Sheet Modal"
    screen show_me_how_onboarding kind list title "Show Me How Onboarding"
    screen siri_favorite kind detail title "Siri Favorite"
    screen splash kind flow title "Splash"
    screen terms_of_service kind list title "Terms Of Service"
    screen theme kind settings title "Theme"
    screen tip kind detail title "Tip"
    screen tips_page kind detail title "Tips Page"
    screen tooltip kind detail title "Tooltip"
    screen tracking_protection kind detail title "Tracking Protection"
  }

  ui_collections {
    screen app_color view list
    screen app_font view list
    screen app_image view list
    screen attributed_link_text view list
    screen card_banner view list
    screen default_browser_onboarding view list
    screen focus_widgets_entry view list
    screen get_started_onboarding view list
    screen internal_crash_reporting_setting view list
    screen internal_setting view list
    screen license_list view list
    screen onboarding_instruction_label view list
    screen onboarding_preview view list
    screen onboarding_search_widget view list
    screen privacy_policy view list
    screen search_widget view list
    screen show_me_how_onboarding view list
    screen terms_of_service view list
  }

  ui_navigation {
    group workspace label "Workspace" placement primary
    screen home group workspace label "Home" visible false
    screen about group workspace label "About" visible false pattern stack_navigation breadcrumb app_color sitemap exclude
    screen add_custom_domain group workspace label "Add Custom Domain" visible false
    screen add_search_engine group workspace label "Add Search Engine" visible false
    screen app_color group workspace label "App Color" default true visible true pattern bottom_tabs
    screen app_font group workspace label "App Font" visible true pattern bottom_tabs
    screen app_image group workspace label "App Image" visible true pattern bottom_tabs
    screen attributed_link_text group workspace label "Attributed Link Text" visible true pattern bottom_tabs
    screen autocomplete_custom_url group workspace label "Autocomplete Custom Url" visible false
    screen autocomplete_setting group workspace label "Autocomplete Setting" visible false
    screen browser group workspace label "Browser" visible false
    screen card_banner group workspace label "Card Banner" visible true pattern bottom_tabs
    screen default_browser_onboarding group workspace label "Default Browser Onboarding" visible true pattern bottom_tabs
    screen focus_widgets_entry group workspace label "Focus Widgets Entry" visible true pattern bottom_tabs
    screen get_started_onboarding group workspace label "Get Started Onboarding" visible true pattern bottom_tabs
    screen internal_crash_reporting_setting group workspace label "Internal Crash Reporting Setting" visible true pattern bottom_tabs
    screen internal_setting group workspace label "Internal Setting" visible true pattern bottom_tabs
    screen legacy_web group workspace label "Legacy Web" visible false
    screen license_list group workspace label "License List" visible true pattern bottom_tabs
    screen onboarding group workspace label "Onboarding" visible false
    screen onboarding_instruction_label group workspace label "Onboarding Instruction Label" visible true pattern bottom_tabs
    screen onboarding_preview group workspace label "Onboarding Preview" visible true pattern bottom_tabs
    screen onboarding_search_widget group workspace label "Onboarding Search Widget" visible true pattern bottom_tabs
    screen photon_action_sheet group workspace label "Photon Action Sheet" visible false
    screen privacy_policy group workspace label "Privacy Policy" visible true pattern bottom_tabs
    screen safari_instruction group workspace label "Safari Instruction" visible false
    screen search_setting group workspace label "Search Setting" visible false
    screen search_widget group workspace label "Search Widget" visible true pattern bottom_tabs
    screen setting group workspace label "Setting" visible false
    screen settings_content group workspace label "Settings Content" visible false
    screen share_tracker group workspace label "Share Tracker" visible false
    screen sheet_modal group workspace label "Sheet Modal" visible false
    screen show_me_how_onboarding group workspace label "Show Me How Onboarding" visible true pattern bottom_tabs
    screen siri_favorite group workspace label "Siri Favorite" visible false pattern stack_navigation breadcrumb app_color sitemap exclude
    screen splash group workspace label "Splash" visible false
    screen terms_of_service group workspace label "Terms Of Service" visible true pattern bottom_tabs
    screen theme group workspace label "Theme" visible false
    screen tip group workspace label "Tip" visible false pattern stack_navigation breadcrumb app_color sitemap exclude
    screen tips_page group workspace label "Tips Page" visible false pattern stack_navigation breadcrumb app_color sitemap exclude
    screen tooltip group workspace label "Tooltip" visible false pattern stack_navigation breadcrumb app_color sitemap exclude
    screen tracking_protection group workspace label "Tracking Protection" visible false pattern stack_navigation breadcrumb app_color sitemap exclude
  }

  ui_screen_regions {
    screen about region summary pattern detail_panel placement primary
    screen app_color region toolbar pattern action_bar placement primary
    screen app_color region results pattern search_results placement primary
    screen app_font region toolbar pattern action_bar placement primary
    screen app_font region results pattern search_results placement primary
    screen app_image region toolbar pattern action_bar placement primary
    screen app_image region results pattern search_results placement primary
    screen attributed_link_text region toolbar pattern action_bar placement primary
    screen attributed_link_text region results pattern search_results placement primary
    screen card_banner region toolbar pattern action_bar placement primary
    screen card_banner region results pattern search_results placement primary
    screen default_browser_onboarding region toolbar pattern action_bar placement primary
    screen default_browser_onboarding region results pattern search_results placement primary
    screen focus_widgets_entry region toolbar pattern action_bar placement primary
    screen focus_widgets_entry region results pattern search_results placement primary
    screen get_started_onboarding region toolbar pattern action_bar placement primary
    screen get_started_onboarding region results pattern search_results placement primary
    screen internal_crash_reporting_setting region toolbar pattern action_bar placement primary
    screen internal_crash_reporting_setting region results pattern search_results placement primary
    screen internal_setting region toolbar pattern action_bar placement primary
    screen internal_setting region results pattern search_results placement primary
    screen license_list region toolbar pattern action_bar placement primary
    screen license_list region results pattern search_results placement primary
    screen onboarding_instruction_label region toolbar pattern action_bar placement primary
    screen onboarding_instruction_label region results pattern search_results placement primary
    screen onboarding_preview region toolbar pattern action_bar placement primary
    screen onboarding_preview region results pattern search_results placement primary
    screen onboarding_search_widget region toolbar pattern action_bar placement primary
    screen onboarding_search_widget region results pattern search_results placement primary
    screen privacy_policy region toolbar pattern action_bar placement primary
    screen privacy_policy region results pattern search_results placement primary
    screen search_widget region toolbar pattern action_bar placement primary
    screen search_widget region results pattern search_results placement primary
    screen show_me_how_onboarding region toolbar pattern action_bar placement primary
    screen show_me_how_onboarding region results pattern search_results placement primary
    screen siri_favorite region summary pattern detail_panel placement primary
    screen terms_of_service region toolbar pattern action_bar placement primary
    screen terms_of_service region results pattern search_results placement primary
    screen tip region summary pattern detail_panel placement primary
    screen tips_page region summary pattern detail_panel placement primary
    screen tooltip region summary pattern detail_panel placement primary
    screen tracking_protection region summary pattern detail_panel placement primary
  }

  status proposed
}
