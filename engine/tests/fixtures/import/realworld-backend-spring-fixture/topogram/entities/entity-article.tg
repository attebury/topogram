# imported confidence: high
# imported source_kind: schema
# imported provenance: service/src/main/resources/db/changelog/changes/01-schema.xml
entity entity_article {
  name "Article"
  description "Candidate entity imported from brownfield schema evidence"

  fields {
    id bigint required
    slug varchar_255 required
    title varchar_255 required
    description varchar_500 required
    body text required
    tag_list text required
    favorites_count bigint required
    created_at timestamp_with_time_zone required
    updated_at timestamp_with_time_zone required
  }

  keys {
    primary [id]
    unique [slug]
  }

  status active
}
