entity entity_user {
  name "User"
  description "Candidate entity imported from brownfield schema evidence"

  fields {
    id bigint required
    username varchar_64 required
    email varchar_255 required
    password varchar_255 required
    bio text required
    updated_at timestamp_with_time_zone required
  }

  keys {
    primary [id]
    unique [username, email]
  }

  status active
}
