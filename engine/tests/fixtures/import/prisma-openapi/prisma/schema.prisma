generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum task_priority {
  low
  medium
  high
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  tasks     Task[]
}

model Task {
  id        String        @id @default(uuid())
  title     String
  priority  task_priority @default(medium)
  ownerId   String?
  owner     User?         @relation(fields: [ownerId], references: [id])

  @@index([ownerId, priority])
}
