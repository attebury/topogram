# AccuTrac-flavored domain fixture for Phase 1 domain-support golden tests.
# 3 domains (rnf, feed_inventory, drugtrac), ~10 capabilities, ~15 entities,
# mix of tagged and cross-cutting (untagged) statements, plus projections
# across two platforms so domain-coverage has data to compute.

actor actor_feed_caller {
  name "Feed Caller"
  description "Calls the daily ration"
  status active
}

actor actor_feed_mill_supervisor {
  name "Feed Mill Supervisor"
  description "Owns commodity master data"
  status active
}

actor actor_doctor {
  name "Doctor"
  description "Treats sick animals"
  status active
}

role role_feedyard_manager {
  name "Feedyard Manager"
  description "Approves daily plans"
  status active
}

domain dom_rnf {
  name "Read-N-Feed"
  description "Daily feed-call workflow and ration delivery"
  in_scope [
    "Daily ration calls per pen"
    "Route assignment and load monitoring"
    "Partial-load drafts and resume"
  ]
  out_of_scope [
    "Commodity master data (see dom_feed_inventory)"
    "Withdrawal compliance (see dom_drugtrac)"
  ]
  owners [actor_feed_caller, role_feedyard_manager]
  aliases ["RNF"]
  status active
}

domain dom_feed_inventory {
  name "Feed Inventory System"
  description "Commodity master, storage bins, milling, contracts"
  in_scope [
    "Commodity master data and nutrient profiles"
    "Storage bin definition and tracking"
    "Physical inventory counts and adjustments"
  ]
  owners [actor_feed_mill_supervisor]
  aliases ["FIS"]
  status active
}

domain dom_drugtrac {
  name "DrugTrac"
  description "Treatment records, withdrawal compliance, regulatory holds"
  in_scope [
    "Treatment recording with route and dose"
    "Withdrawal-period tracking per animal"
  ]
  owners [actor_doctor]
  status active
}

# --- Cross-cutting (untagged) ---
entity entity_party {
  name "Party"
  description "Person or organization"
  fields {
    id string required
    name string required
  }
  status active
}

entity entity_pen {
  name "Pen"
  description "Physical pen housing animals"
  fields {
    code string required
    capacity number required
  }
  status active
}

# --- dom_rnf members ---
entity entity_route {
  name "Route"
  description "Ordered list of pens"
  domain dom_rnf
  fields {
    code string required
    pens array required
  }
  status active
}

entity entity_feed_call {
  name "Feed Call"
  description "Single call against a pen"
  domain dom_rnf
  fields {
    pen string required
    ration string required
    pounds number required
  }
  status active
}

capability cap_call_feed {
  name "Call Feed"
  description "Daily feed-calling workflow"
  domain dom_rnf
  actors [actor_feed_caller]
  reads [entity_pen, entity_route]
  creates [entity_feed_call]
  status active
}

capability cap_monitor_loads {
  name "Monitor Loads"
  description "Watch loads as they leave the mill"
  domain dom_rnf
  actors [actor_feed_caller]
  reads [entity_feed_call]
  status active
}

rule rule_draft_persistence {
  name "Draft persistence"
  description "Drafts must persist across app restart"
  applies_to [cap_call_feed]
  domain dom_rnf
  severity warning
  status active
}

verification verification_call_feed_save {
  name "Call Feed save"
  description "Save round-trip preserves draft"
  validates [cap_call_feed]
  domain dom_rnf
  method runtime
  scenarios [save_then_resume, partial_load_offline]
  status active
}

# --- dom_feed_inventory members ---
entity entity_commodity {
  name "Commodity"
  description "Master record for a commodity ingredient"
  domain dom_feed_inventory
  fields {
    code string required
    description string required
  }
  status active
}

entity entity_storage_bin {
  name "Storage Bin"
  description "Physical bin holding a commodity"
  domain dom_feed_inventory
  fields {
    code string required
    capacity number required
  }
  status active
}

entity entity_inventory_count {
  name "Inventory Count"
  description "Physical count event"
  domain dom_feed_inventory
  fields {
    bin string required
    pounds number required
  }
  status active
}

capability cap_record_inventory_count {
  name "Record Inventory Count"
  description "Capture a physical count"
  domain dom_feed_inventory
  actors [actor_feed_mill_supervisor]
  reads [entity_storage_bin, entity_commodity]
  creates [entity_inventory_count]
  status active
}

capability cap_manage_commodities {
  name "Manage Commodities"
  description "CRUD on commodity master"
  domain dom_feed_inventory
  actors [actor_feed_mill_supervisor]
  reads [entity_commodity]
  creates [entity_commodity]
  status active
}

rule rule_levy_calc {
  name "Grain levy calculation"
  description "Levy is computed at receipt time"
  applies_to [cap_record_inventory_count]
  domain dom_feed_inventory
  severity error
  status active
}

# --- dom_drugtrac members ---
entity entity_treatment {
  name "Treatment"
  description "Single treatment event for an animal"
  domain dom_drugtrac
  fields {
    animal string required
    drug string required
    dose number required
  }
  status active
}

entity entity_withdrawal_period {
  name "Withdrawal Period"
  description "Withdrawal window for a drug"
  domain dom_drugtrac
  fields {
    drug string required
    days number required
  }
  status active
}

capability cap_record_treatment {
  name "Record Treatment"
  description "Doctor records a treatment event"
  domain dom_drugtrac
  actors [actor_doctor]
  reads [entity_withdrawal_period]
  creates [entity_treatment]
  status active
}

capability cap_check_safe_to_ship {
  name "Check Safe to Ship"
  description "Verify all withdrawal periods cleared"
  domain dom_drugtrac
  actors [actor_doctor]
  reads [entity_treatment, entity_withdrawal_period]
  status active
}

verification verification_safe_to_ship {
  name "Safe to ship"
  description "Withdrawal compliance gate"
  validates [cap_check_safe_to_ship]
  domain dom_drugtrac
  method contract
  scenarios [no_active_withdrawals, blocked_when_active]
  status active
}

# --- Projections (cross-platform realization) ---
projection proj_rnf_desktop {
  name "RNF Desktop"
  description "Adobe Flex desktop projection"
  platform desktop
  realizes [cap_call_feed, cap_monitor_loads]
  outputs [flex_swf]
  status active
}

projection proj_rnf_mobile {
  name "RNF Mobile"
  description "MAUI mobile projection"
  platform maui
  realizes [cap_call_feed]
  outputs [mobile_app]
  status active
}

projection proj_drugtrac_desktop {
  name "DrugTrac Desktop"
  description "Desktop projection"
  platform desktop
  realizes [cap_record_treatment, cap_check_safe_to_ship]
  outputs [flex_swf]
  status active
}

projection proj_inventory_desktop {
  name "Inventory Desktop"
  description "Desktop projection"
  platform desktop
  realizes [cap_record_inventory_count, cap_manage_commodities]
  outputs [flex_swf]
  status active
}
