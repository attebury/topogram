{
  "version": "0.1",
  "implementation": {
    "id": "app-basic-fixture",
    "module": "./implementation/index.js",
    "export": "APP_BASIC_IMPLEMENTATION"
  },
  "outputs": {
    "app": {
      "path": "./app",
      "ownership": "generated"
    }
  },
  "topology": {
    "runtimes": [
      {
        "id": "app_api",
        "projection": "proj_api",
        "generator": {
          "id": "topogram/hono",
          "version": "1"
        },
        "port": 3000,
        "kind": "api_service",
        "uses_database": "app_postgres"
      },
      {
        "id": "app_sveltekit",
        "projection": "proj_web_surface",
        "generator": {
          "id": "topogram/sveltekit",
          "version": "1"
        },
        "port": 5173,
        "kind": "web_surface",
        "uses_api": "app_api"
      },
      {
        "id": "app_postgres",
        "projection": "proj_db_postgres",
        "generator": {
          "id": "topogram/postgres",
          "version": "1"
        },
        "port": 5432,
        "kind": "database"
      }
    ]
  }
}
