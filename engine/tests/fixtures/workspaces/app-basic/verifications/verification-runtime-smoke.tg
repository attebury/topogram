verification ver_runtime_smoke {
  name "Work Tracker runtime smoke"
  description "Covers the minimum web and API checks for the generated work-tracker stack."

  validates [cap_create_task, cap_get_task, cap_list_tasks]
  method smoke

  scenarios [
    tasks_page_responds,
    create_task_smoke,
    get_created_task_smoke,
    list_tasks_smoke
  ]

  status active
}
