generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CollectionStatus {
  active
  archived
}

enum ItemPriority {
  low
  medium
  high
}

enum ItemStatus {
  draft
  active
  completed
  archived
}

model Collection {
  created_at DateTime @db.Timestamptz(3)
  description String?
  id String @id @db.Uuid
  name String @unique
  owner_id String? @db.Uuid
  owner Member? @relation("Collection_owner_id_to_Member", fields: [owner_id], references: [id])
  status CollectionStatus @default(active)
  items Item[] @relation("Item_collection_id_to_Collection")
  @@index([owner_id, status])
  @@map("collections")
}

model Item {
  collection_id String @db.Uuid
  collection Collection @relation("Item_collection_id_to_Collection", fields: [collection_id], references: [id])
  completed_at DateTime? @db.Timestamptz(3)
  created_at DateTime @db.Timestamptz(3)
  description String?
  due_at DateTime? @db.Timestamptz(3)
  id String @id @db.Uuid
  owner_id String? @db.Uuid
  owner Member? @relation("Item_owner_id_to_Member", fields: [owner_id], references: [id])
  priority ItemPriority @default(medium)
  status ItemStatus @default(draft)
  title String
  updated_at DateTime @db.Timestamptz(3)
  @@index([collection_id, status])
  @@index([owner_id, status])
  @@map("items")
}

model Member {
  created_at DateTime @db.Timestamptz(3)
  display_name String
  email String @unique
  id String @id @db.Uuid
  is_active Boolean @default(true)
  collections Collection[] @relation("Collection_owner_id_to_Member")
  items Item[] @relation("Item_owner_id_to_Member")
  @@map("members")
}
