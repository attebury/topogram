{
  "type": "app_bundle_plan",
  "name": "Topogram Sample Workspace App Bundle",
  "projections": {
    "api": "proj_api",
    "ui": "proj_web_surface",
    "db": "proj_db_postgres",
    "dbPlatform": "db_contract"
  },
  "topology": {
    "runtimes": [
      {
        "id": "app_api",
        "kind": "api_service",
        "projection": "proj_api",
        "generator": {
          "id": "topogram/hono",
          "version": "1"
        },
        "port": 3000,
        "uses_api": null,
        "uses_database": "app_postgres"
      },
      {
        "id": "app_sveltekit",
        "kind": "web_surface",
        "projection": "proj_web_surface",
        "generator": {
          "id": "topogram/sveltekit",
          "version": "1"
        },
        "port": 5173,
        "uses_api": "app_api",
        "uses_database": null
      },
      {
        "id": "app_postgres",
        "kind": "database",
        "projection": "proj_db_postgres",
        "generator": {
          "id": "topogram/postgres",
          "version": "1"
        },
        "port": 5432,
        "uses_api": null,
        "uses_database": null
      }
    ]
  },
  "runtimeReference": {
    "localDbProjectionId": "proj_db_postgres",
    "serviceName": "topogram-sample-workspace-server",
    "ports": {
      "server": 3000,
      "web": 5173
    },
    "environment": {
      "name": "Sample Workspace Local Runtime Stack",
      "databaseName": "topogram_sample_workspace",
      "envExample": "TOPOGRAM_AUTH_PROFILE=bearer_demo\nTOPOGRAM_AUTH_TOKEN=topogram-sample-workspace-demo-token\nTOPOGRAM_AUTH_USER_ID=11111111-1111-4111-8111-111111111111\nTOPOGRAM_AUTH_PERMISSIONS=*\nPUBLIC_TOPOGRAM_AUTH_TOKEN=topogram-sample-workspace-demo-token\nPUBLIC_TOPOGRAM_AUTH_USER_ID=11111111-1111-4111-8111-111111111111\nPUBLIC_TOPOGRAM_AUTH_PERMISSIONS=*\nPUBLIC_TOPOGRAM_DEMO_PRIMARY_ID=33333333-3333-4333-8333-333333333333\nPUBLIC_TOPOGRAM_DEMO_CONTAINER_ID=22222222-2222-4222-8222-222222222222\nTOPOGRAM_DEMO_PRIMARY_ID=33333333-3333-4333-8333-333333333333\nTOPOGRAM_DEMO_CONTAINER_ID=22222222-2222-4222-8222-222222222222"
    },
    "compileCheck": {
      "name": "Sample Workspace Generated Compile Checks"
    },
    "smoke": {
      "name": "Sample Workspace Runtime Smoke Plan",
      "bundleTitle": "Sample Workspace Runtime Smoke Bundle",
      "defaultContainerEnvVar": "TOPOGRAM_DEMO_CONTAINER_ID",
      "webPath": "/items",
      "expectText": "Items",
      "createPath": "/items",
      "getPathPrefix": "/items/",
      "listPath": "/items",
      "createPayload": {
        "title": "Smoke Test Item",
        "containerField": "collection_id"
      },
      "verification": {
        "methods": [
          "smoke"
        ],
        "sources": [
          {
            "id": "ver_runtime_smoke",
            "name": "Sample Workspace runtime smoke",
            "method": "smoke",
            "validates": [
              "cap_create_item",
              "cap_get_item",
              "cap_list_items"
            ]
          }
        ],
        "scenarios": [
          {
            "id": "items_page_responds",
            "label": "items page responds"
          },
          {
            "id": "create_item_smoke",
            "label": "create item smoke"
          },
          {
            "id": "get_created_item_smoke",
            "label": "get created item smoke"
          },
          {
            "id": "list_items_smoke",
            "label": "list items smoke"
          }
        ]
      }
    },
    "runtimeCheck": {
      "name": "Sample Workspace Runtime Check Plan",
      "bundleTitle": "Sample Workspace Runtime Check Bundle",
      "requiredEnv": [
        "TOPOGRAM_API_BASE_URL",
        "TOPOGRAM_WEB_BASE_URL",
        "TOPOGRAM_DEMO_CONTAINER_ID",
        "TOPOGRAM_DEMO_PRIMARY_ID"
      ],
      "demoContainerEnvVar": "TOPOGRAM_DEMO_CONTAINER_ID",
      "demoPrimaryEnvVar": "TOPOGRAM_DEMO_PRIMARY_ID",
      "lookupPaths": {
        "collection": "/lookups/collections",
        "member": "/lookups/members"
      },
      "stageNotes": [
        {
          "id": "environment",
          "summary": "required env, web readiness, API health, API readiness, and DB-backed seeded item lookup"
        },
        {
          "id": "api",
          "summary": "core item happy paths, export/job flows, generated lookup endpoints, and important negative cases"
        }
      ],
      "notes": [
        "Mutating checks create, update, complete, and archive a runtime-check item.",
        "Export checks submit a item export job, verify job status, and verify the download endpoint.",
        "Runtime checks also verify the generated collection and member lookup endpoints.",
        "Later stages are skipped if environment readiness fails.",
        "The generated server exposes both `/health` and `/ready`.",
        "Use the smoke bundle for a faster minimal confidence check.",
        "Use this runtime-check bundle for richer staged verification and JSON reporting."
      ],
      "verification": {
        "methods": [
          "runtime"
        ],
        "sources": [
          {
            "id": "ver_create_item_policy",
            "name": "Create item policy",
            "method": "runtime",
            "validates": [
              "cap_create_item",
              "rule_no_item_creation_in_archived_collection",
              "rule_only_active_members_may_own_items"
            ]
          },
          {
            "id": "ver_item_runtime_flow",
            "name": "Item runtime flow",
            "method": "runtime",
            "validates": [
              "cap_create_item",
              "cap_get_item",
              "cap_list_items",
              "cap_update_item",
              "cap_complete_item",
              "cap_delete_item",
              "cap_export_items",
              "cap_get_item_export_job",
              "cap_download_item_export"
            ]
          }
        ],
        "scenarios": [
          {
            "id": "create_item_in_active_collection",
            "label": "create item in active collection"
          },
          {
            "id": "reject_item_in_archived_collection",
            "label": "reject item in archived collection"
          },
          {
            "id": "reject_assignment_to_inactive_member",
            "label": "reject assignment to inactive member"
          },
          {
            "id": "create_item_runtime",
            "label": "create item runtime"
          },
          {
            "id": "get_created_item_runtime",
            "label": "get created item runtime"
          },
          {
            "id": "list_items_runtime",
            "label": "list items runtime"
          },
          {
            "id": "update_item_runtime",
            "label": "update item runtime"
          },
          {
            "id": "complete_item_runtime",
            "label": "complete item runtime"
          },
          {
            "id": "delete_item_runtime",
            "label": "delete item runtime"
          },
          {
            "id": "export_items_runtime",
            "label": "export items runtime"
          },
          {
            "id": "get_item_export_job_runtime",
            "label": "get item export job runtime"
          },
          {
            "id": "download_item_export_runtime",
            "label": "download item export runtime"
          }
        ]
      }
    },
    "appBundle": {
      "name": "Topogram Sample Workspace App Bundle",
      "demoContainerName": "Demo Collection",
      "demoPrimaryTitle": "Seeded Demo Item"
    },
    "demoEnv": {
      "memberId": "11111111-1111-4111-8111-111111111111",
      "containerId": "22222222-2222-4222-8222-222222222222",
      "primaryId": "33333333-3333-4333-8333-333333333333"
    }
  },
  "profiles": {
    "environment": "local_process",
    "deployment": "fly_io"
  },
  "commands": {
    "bootstrap": "./scripts/bootstrap.sh",
    "dev": "./scripts/dev.sh",
    "compile": "./scripts/compile-check.sh",
    "runtime": "./scripts/runtime.sh",
    "smoke": "./scripts/smoke.sh",
    "runtimeCheck": "./scripts/runtime-check.sh",
    "deployCheck": "./scripts/deploy-check.sh"
  },
  "layout": {
    "apps": "apps",
    "deploy": "deploy",
    "smoke": "smoke",
    "runtimeCheck": "runtime-check",
    "compile": "compile",
    "services": "apps/services",
    "web": "apps/web",
    "db": "apps/db",
    "native": "apps/native"
  }
}
