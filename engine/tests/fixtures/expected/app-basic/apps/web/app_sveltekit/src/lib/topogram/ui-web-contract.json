  "components": {
    "component_ui_data_grid": {
      "type": "component_contract",
      "id": "component_ui_data_grid",
      "name": "Data Grid",
      "description": "Reusable tabular display for item rows",
      "category": "collection",
      "version": "1.0",
      "status": "active",
      "props": [
        {
          "name": "rows",
          "type": "array",
          "requiredness": "required",
          "defaultValue": null
        },
        {
          "name": "selected_ids",
          "type": "array",
          "requiredness": "optional",
          "defaultValue": []
        },
        {
          "name": "loading",
          "type": "boolean",
          "requiredness": "optional",
          "defaultValue": false
        }
      ],
      "events": [
        {
          "id": "row_select",
          "shape": {
            "id": "shape_output_item_card",
            "kind": "shape"
          }
        }
      ],
      "slots": [
        {
          "id": "toolbar",
          "description": "Toolbar actions"
        },
        {
          "id": "empty_state",
          "description": "Empty-state content"
        }
      ],
      "behavior": [
        "selection",
        "sorting"
      ],
      "behaviors": [
        {
          "kind": "selection",
          "directives": {
            "mode": "multi",
            "state": "selected_ids",
            "emits": "row_select"
          },
          "source": "structured"
        },
        {
          "kind": "sorting",
          "directives": {
            "fields": [
              "title",
              "status",
              "created_at"
            ],
            "default": [
              "created_at",
              "desc"
            ]
          },
          "source": "structured"
        }
      ],
      "patterns": [
        "resource_table",
        "data_grid_view"
      ],
      "regions": [
        "results",
        "toolbar"
      ],
      "approvals": [],
      "lookups": [],
      "dependencies": []
    }
  },
