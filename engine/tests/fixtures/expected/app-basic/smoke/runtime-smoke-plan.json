{
  "type": "runtime_smoke_plan",
  "name": "Sample Workspace Runtime Smoke Plan",
  "projections": {
    "api": "proj_api",
    "ui": "proj_ui_web"
  },
  "topology": {
    "components": [
      {
        "id": "app_api",
        "type": "api",
        "projection": "proj_api",
        "generator": {
          "id": "topogram/hono",
          "version": "1"
        }
      },
      {
        "id": "app_sveltekit",
        "type": "web",
        "projection": "proj_ui_web",
        "generator": {
          "id": "topogram/sveltekit",
          "version": "1"
        }
      },
      {
        "id": "app_postgres",
        "type": "database",
        "projection": "proj_db_postgres",
        "generator": {
          "id": "topogram/postgres",
          "version": "1"
        }
      }
    ]
  },
  "verification": {
    "methods": [
      "smoke"
    ],
    "sources": [
      {
        "id": "ver_runtime_smoke",
        "name": "Sample Workspace runtime smoke",
        "method": "smoke",
        "validates": [
          "cap_create_item",
          "cap_get_item",
          "cap_list_items"
        ]
      }
    ],
    "scenarios": [
      {
        "id": "items_page_responds",
        "label": "items page responds"
      },
      {
        "id": "create_item_smoke",
        "label": "create item smoke"
      },
      {
        "id": "get_created_item_smoke",
        "label": "get created item smoke"
      },
      {
        "id": "list_items_smoke",
        "label": "list items smoke"
      }
    ]
  },
  "env": {
    "apiBase": "TOPOGRAM_API_BASE_URL",
    "webBase": "TOPOGRAM_WEB_BASE_URL"
  },
  "checks": [
    {
      "id": "web_items_page",
      "type": "web_get",
      "path": "/items",
      "expectStatus": 200,
      "expectText": "Items"
    },
    {
      "id": "create_item",
      "type": "api_post",
      "path": "/items",
      "expectStatus": 201,
      "capabilityId": "cap_create_item"
    },
    {
      "id": "get_item",
      "type": "api_get",
      "path": "/items/:id",
      "expectStatus": 200,
      "capabilityId": "cap_get_item"
    },
    {
      "id": "list_items",
      "type": "api_get",
      "path": "/items",
      "expectStatus": 200,
      "capabilityId": "cap_list_items"
    }
  ]
}
