{
  "version": "0.1",
  "implementation": {
    "id": "todo-demo-app",
    "module": "./implementation/index.js",
    "export": "TODO_IMPLEMENTATION"
  },
  "outputs": {
    "app": {
      "path": "./app",
      "ownership": "generated"
    }
  },
  "topology": {
    "components": [
      {
        "id": "todo_api",
        "type": "api",
        "projection": "proj_api",
        "generator": {
          "id": "topogram/hono",
          "version": "1"
        },
        "port": 3000,
        "database": "todo_postgres"
      },
      {
        "id": "todo_sveltekit",
        "type": "web",
        "projection": "proj_ui_web",
        "generator": {
          "id": "topogram/sveltekit",
          "version": "1"
        },
        "port": 5173,
        "api": "todo_api"
      },
      {
        "id": "todo_postgres",
        "type": "database",
        "projection": "proj_db_postgres",
        "generator": {
          "id": "topogram/postgres",
          "version": "1"
        },
        "port": 5432
      }
    ]
  }
}
