{
  "type": "runtime_smoke_plan",
  "name": "Content Approval Runtime Smoke Plan",
  "projections": {
    "api": "proj_api",
    "ui": "proj_ui_web__sveltekit"
  },
  "verification": {
    "methods": [
      "smoke"
    ],
    "sources": [
      {
        "id": "ver_runtime_smoke",
        "name": "Content approval runtime smoke",
        "method": "smoke",
        "validates": [
          "cap_create_article",
          "cap_get_article",
          "cap_list_articles"
        ]
      }
    ],
    "scenarios": [
      {
        "id": "articles_page_responds",
        "label": "articles page responds"
      },
      {
        "id": "create_article_smoke",
        "label": "create article smoke"
      },
      {
        "id": "get_created_article_smoke",
        "label": "get created article smoke"
      },
      {
        "id": "list_articles_smoke",
        "label": "list articles smoke"
      }
    ]
  },
  "env": {
    "apiBase": "TOPOGRAM_API_BASE_URL",
    "webBase": "TOPOGRAM_WEB_BASE_URL"
  },
  "checks": [
    {
      "id": "web_articles_page",
      "type": "web_get",
      "path": "/articles",
      "expectStatus": 200,
      "expectText": "Articles"
    },
    {
      "id": "create_article",
      "type": "api_post",
      "path": "/articles",
      "expectStatus": 201,
      "capabilityId": "cap_create_article"
    },
    {
      "id": "get_article",
      "type": "api_get",
      "path": "/articles/:id",
      "expectStatus": 200,
      "capabilityId": "cap_get_article"
    },
    {
      "id": "list_articles",
      "type": "api_get",
      "path": "/articles",
      "expectStatus": 200,
      "capabilityId": "cap_list_articles"
    }
  ]
}
