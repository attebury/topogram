rule rule_only_active_users_may_review_articles {
  name "Only active users may review articles"
  description "Assigned reviewers must be active users"

  applies_to [cap_create_article, cap_update_article, cap_approve_article, cap_reject_article]
  actors [actor_manager]
  roles [role_manager]
  requirement "reviewer.is_active == true"
  severity error

  status active
}
