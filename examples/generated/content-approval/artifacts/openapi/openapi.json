  "info": {
    "title": "Topogram API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/articles": {
      "get": {
        "description": "Lists articles across draft, submitted, approved, and rejected states",
        "operationId": "cap_list_articles",
        "parameters": [
          {
            "in": "query",
            "name": "publication_id",
            "required": false,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "reviewer_id",
            "required": false,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "status",
            "required": false,
            "schema": {
              "enum": [
                "draft",
                "submitted",
                "approved",
                "rejected"
              ],
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "after",
            "required": false,
            "schema": {
              "format": "date-time",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputArticleDetailCursorPageResponse"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/CapListArticlesInvalidRequestError"
                    },
                    {
                      "$ref": "#/components/schemas/CapListArticlesInvalidCursorError"
                    },
                    {
                      "$ref": "#/components/schemas/CapListArticlesInvalidLimitError"
                    }
                  ]
                }
              }
            },
            "description": "Error (400)"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List Articles",
        "x-topogram-authorization": [
          {
            "permission": "articles.read"
          }
        ]
      },
      "post": {
        "description": "Creates a new article draft",
        "operationId": "cap_create_article",
        "parameters": [
          {
            "in": "header",
            "name": "Idempotency-Key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShapeInputCreateArticleRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputArticleDetailResponse"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/RuleOnlyActiveUsersMayReviewArticlesError"
                    },
                    {
                      "$ref": "#/components/schemas/CapCreateArticleInvalidRequestError"
                    }
                  ]
                }
              }
            },
            "description": "Error (400)"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/RuleNoArticleCreationInArchivedPublicationError"
                    },
                    {
                      "$ref": "#/components/schemas/CapCreateArticleIdempotencyConflictError"
                    }
                  ]
                }
              }
            },
            "description": "Error (409)"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Create Article",
        "x-topogram-authorization": [
          {
            "permission": "articles.create"
          }
        ]
      }
    },
    "/articles/{id}": {
      "get": {
        "description": "Fetches a single article",
        "operationId": "cap_get_article",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "If-None-Match",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputArticleDetailResponse"
                }
              }
            },
            "description": "Success",
            "headers": {
              "ETag": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "304": {
            "description": "Not Modified",
            "headers": {
              "ETag": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/CapGetArticleInvalidRequestErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/CapGetArticleNotFoundErrorResponse"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get Article",
        "x-topogram-authorization": [
          {
            "ownership": "owner_or_admin"
          }
        ]
      },
      "patch": {
        "description": "Updates an article draft or submits it for review",
        "operationId": "cap_update_article",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "If-Match",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShapeInputUpdateArticleRequest"
              }
            }
          },
          "required": false
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputArticleDetailResponse"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/RuleOnlyActiveUsersMayReviewArticlesError"
                    },
                    {
                      "$ref": "#/components/schemas/CapUpdateArticleInvalidRequestError"
                    }
                  ]
                }
              }
            },
            "description": "Error (400)"
          },
          "412": {
            "$ref": "#/components/responses/CapUpdateArticlePreconditionFailedErrorResponse"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Update Article",
        "x-topogram-authorization": [
          {
            "ownership": "owner_or_admin",
            "permission": "articles.submit"
          }
        ]
      }
    },
    "/articles/{id}/approve": {
      "post": {
        "description": "Approves a submitted article",
        "operationId": "cap_approve_article",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "If-Match",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "Idempotency-Key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShapeInputApproveArticleRequest"
              }
            }
          },
          "required": false
        },
        "responses": {
          "200": {
