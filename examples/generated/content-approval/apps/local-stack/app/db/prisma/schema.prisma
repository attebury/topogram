generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  approved_at DateTime?
  category String?
  created_at DateTime
  description String?
  id String @id
  publication_id String
  publication Publication @relation("Article_publication_id_to_Publication", fields: [publication_id], references: [id])
  rejected_at DateTime?
  reviewer_id String?
  reviewer User? @relation("Article_reviewer_id_to_User", fields: [reviewer_id], references: [id])
  reviewer_notes String?
  revision_requested_at DateTime?
  status String @default("draft")
  submitted_at DateTime?
  title String
  updated_at DateTime
  @@index([publication_id, status])
  @@index([reviewer_id, status])
  @@map("articles")
}

model Publication {
  created_at DateTime
  description String?
  id String @id
  name String @unique
  status String @default("active")
  articles Article[] @relation("Article_publication_id_to_Publication")
  @@map("publications")
}

model User {
  created_at DateTime
  display_name String
  email String @unique
  id String @id
  is_active Boolean @default(true)
  articles Article[] @relation("Article_reviewer_id_to_User")
  @@map("users")
}
