{
  "deployment": {
    "name": "Topogram Todo Deployment Stack",
    "profile": "railway"
  },
  "projections": {
    "api": "proj_api",
    "db": "proj_db_postgres",
    "ui": "proj_ui_web__sveltekit"
  },
  "recommendedCommands": {
    "deployServer": "railway up",
    "deployWeb": "vercel deploy",
    "migrate": "npm run db:migrate"
  },
  "requiredEnv": [
    "DATABASE_URL",
    "PUBLIC_TOPOGRAM_API_BASE_URL"
  ],
  "runtime": {
    "orm": "prisma",
    "server": "hono",
    "web": "sveltekit"
  },
  "targets": {
    "database": "railway_postgres",
    "server": "railway",
    "web": "vercel"
  },
  "type": "deployment_plan"
}
