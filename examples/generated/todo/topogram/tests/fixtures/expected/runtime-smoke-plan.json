{
  "checks": [
    {
      "expectStatus": 200,
      "expectText": "Tasks",
      "id": "web_tasks_page",
      "path": "/tasks",
      "type": "web_get"
    },
    {
      "capabilityId": "cap_create_task",
      "expectStatus": 201,
      "id": "create_task",
      "path": "/tasks",
      "type": "api_post"
    },
    {
      "capabilityId": "cap_get_task",
      "expectStatus": 200,
      "id": "get_task",
      "path": "/tasks/:id",
      "type": "api_get"
    },
    {
      "capabilityId": "cap_list_tasks",
      "expectStatus": 200,
      "id": "list_tasks",
      "path": "/tasks",
      "type": "api_get"
    }
  ],
  "env": {
    "apiBase": "TOPOGRAM_API_BASE_URL",
    "webBase": "TOPOGRAM_WEB_BASE_URL"
  },
  "name": "Todo Runtime Smoke Plan",
  "projections": {
    "api": "proj_api",
    "ui": "proj_ui_web__sveltekit"
  },
  "type": "runtime_smoke_plan",
  "verification": {
    "methods": [
      "smoke"
    ],
    "scenarios": [
      {
        "id": "tasks_page_responds",
        "label": "tasks page responds"
      },
      {
        "id": "create_task_smoke",
        "label": "create task smoke"
      },
      {
        "id": "get_created_task_smoke",
        "label": "get created task smoke"
      },
      {
        "id": "list_tasks_smoke",
        "label": "list tasks smoke"
      }
    ],
    "sources": [
      {
        "id": "ver_runtime_smoke",
        "method": "smoke",
        "name": "Todo runtime smoke",
        "validates": [
          "cap_create_task",
          "cap_get_task",
          "cap_list_tasks"
        ]
      }
    ]
  }
}
