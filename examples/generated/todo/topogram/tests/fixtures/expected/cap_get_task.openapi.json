{
  "components": {
    "responses": {
      "CapGetTaskInvalidRequestErrorResponse": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CapGetTaskInvalidRequestError"
            }
          }
        },
        "description": "Cap Get Task Invalid Request (400)"
      },
      "CapGetTaskNotFoundErrorResponse": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CapGetTaskNotFoundError"
            }
          }
        },
        "description": "Cap Get Task Not Found (404)"
      }
    },
    "schemas": {
      "CapGetTaskInvalidRequestError": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ErrorResponse"
          },
          {
            "properties": {
              "code": {
                "const": "cap_get_task_invalid_request",
                "type": "string"
              }
            },
            "type": "object"
          }
        ],
        "title": "Cap Get Task Invalid Request"
      },
      "CapGetTaskNotFoundError": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ErrorResponse"
          },
          {
            "properties": {
              "code": {
                "const": "cap_get_task_not_found",
                "type": "string"
              }
            },
            "type": "object"
          }
        ],
        "title": "Cap Get Task Not Found"
      },
      "ErrorResponse": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string"
          },
          "details": {
            "additionalProperties": true,
            "type": "object"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      },
      "ShapeOutputTaskDetailResponse": {
        "$id": "topogram:shape:shape_output_task_detail",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "description": "Detailed task payload",
        "properties": {
          "completed_at": {
            "format": "date-time",
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "due_at": {
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "owner_id": {
            "format": "uuid",
            "type": "string"
          },
          "priority": {
            "default": "medium",
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "type": "string"
          },
          "project_id": {
            "format": "uuid",
            "type": "string"
          },
          "status": {
            "default": "draft",
            "enum": [
              "draft",
              "active",
              "completed",
              "archived"
            ],
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "status",
          "priority",
          "project_id",
          "created_at",
          "updated_at"
        ],
        "title": "Task Detail Output",
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "title": "Topogram API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/tasks/{id}": {
      "get": {
        "description": "Allows a user to fetch a single task by id",
        "operationId": "cap_get_task",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "If-None-Match",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputTaskDetailResponse"
                }
              }
            },
            "description": "Success",
            "headers": {
              "ETag": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "304": {
            "description": "Not Modified",
            "headers": {
              "ETag": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/CapGetTaskInvalidRequestErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/CapGetTaskNotFoundErrorResponse"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get Task",
        "x-topogram-authorization": [
          {
            "ownership": "owner_or_admin",
            "ownershipField": "owner_id"
          }
        ]
      }
    }
  }
}
