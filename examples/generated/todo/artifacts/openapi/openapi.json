  "info": {
    "title": "Topogram API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/task-exports/{job_id}": {
      "get": {
        "description": "Fetches the current status of a task export job",
        "operationId": "cap_get_task_export_job",
        "parameters": [
          {
            "in": "path",
            "name": "job_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputTaskExportStatusResponse"
                }
              }
            },
            "description": "Success",
            "links": {
              "cap_download_task_exportDownload": {
                "description": "Use cap_download_task_export when the job is complete",
                "operationId": "cap_download_task_export",
                "parameters": {
                  "job_id": "$response.body#/job_id"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/CapGetTaskExportJobInvalidRequestErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/CapGetTaskExportJobNotFoundErrorResponse"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get Task Export Job",
        "x-topogram-authorization": [
          {
