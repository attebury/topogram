{
  "$id": "topogram:shape:shape_output_task_export_status",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Status payload for long-running task export jobs",
  "properties": {
    "completed_at": {
      "format": "date-time",
      "type": "string"
    },
    "download_url": {
      "type": "string"
    },
    "error_message": {
      "type": "string"
    },
    "expires_at": {
      "format": "date-time",
      "type": "string"
    },
    "job_id": {
      "format": "uuid",
      "type": "string"
    },
    "status": {
      "default": "accepted",
      "enum": [
        "accepted",
        "running",
        "completed",
        "failed",
        "expired"
      ],
      "type": "string"
    },
    "status_url": {
      "type": "string"
    },
    "submitted_at": {
      "format": "date-time",
      "type": "string"
    }
  },
  "required": [
    "job_id",
    "status",
    "status_url",
    "submitted_at"
  ],
  "title": "Task Export Status",
  "type": "object"
}
