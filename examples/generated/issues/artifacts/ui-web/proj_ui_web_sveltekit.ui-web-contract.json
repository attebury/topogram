        "present": "page"
      }
    },
    {
      "actionWeb": {},
      "actions": {
        "destructive": null,
        "primary": null,
        "screen": [],
        "secondary": null,
        "terminal": null
      },
      "collection": {
        "filters": [],
        "pagination": null,
        "search": [],
        "sort": []
      },
      "detailCapability": null,
      "emptyState": null,
      "id": "issue_edit",
      "inputShape": {
        "id": "shape_input_update_issue",
        "kind": "shape"
      },
      "itemShape": null,
      "kind": "form",
      "loadCapability": null,
      "lookups": [
        {
          "emptyLabel": "Unassigned",
          "entity": {
            "id": "entity_user",
            "kind": "entity"
          },
          "field": "assignee_id",
          "labelField": "display_name"
