      },
      "route": "/issues/:id/edit",
      "submitCapability": {
        "id": "cap_update_issue",
        "kind": "capability"
      },
      "title": "Edit Issue",
      "type": "ui_screen_contract",
      "viewShape": null,
      "visibility": [],
      "web": {
        "present": "page"
      }
    }
  ],
  "sharedProjection": {
    "id": "proj_ui_shared",
    "name": "Issues Shared UI"
  }
