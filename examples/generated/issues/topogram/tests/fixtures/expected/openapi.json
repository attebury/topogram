  "info": {
    "title": "Topogram API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/issues": {
      "get": {
        "description": "Lists issues with optional filters",
        "operationId": "cap_list_issues",
        "parameters": [
          {
            "in": "query",
            "name": "board_id",
            "required": false,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "assignee_id",
            "required": false,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "status",
            "required": false,
            "schema": {
              "enum": [
                "open",
                "in_progress",
                "closed",
                "archived"
              ],
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "after",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 25,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputIssueDetailCursorPageResponse"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/CapListIssuesInvalidRequestError"
                    },
                    {
                      "$ref": "#/components/schemas/CapListIssuesInvalidCursorError"
                    },
                    {
                      "$ref": "#/components/schemas/CapListIssuesInvalidLimitError"
                    }
                  ]
                }
              }
            },
            "description": "Error (400)"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List Issues",
        "x-topogram-authorization": [
          {
            "permission": "issues.read"
          }
        ]
      },
      "post": {
        "description": "Allows a user to create a new issue",
        "operationId": "cap_create_issue",
        "parameters": [
          {
            "in": "header",
            "name": "Idempotency-Key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShapeInputCreateIssueRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputIssueDetailResponse"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/RuleOnlyActiveUsersMayBeAssignedIssuesError"
                    },
                    {
                      "$ref": "#/components/schemas/CapCreateIssueInvalidRequestError"
                    }
                  ]
                }
              }
            },
            "description": "Error (400)"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/RuleNoIssueCreationInArchivedBoardError"
                    },
                    {
                      "$ref": "#/components/schemas/CapCreateIssueIdempotencyConflictError"
                    }
                  ]
                }
              }
            },
            "description": "Error (409)"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Create Issue",
        "x-topogram-authorization": [
          {
            "permission": "issues.create"
          }
        ]
      }
    },
    "/issues/{id}": {
      "get": {
        "description": "Loads a single issue",
        "operationId": "cap_get_issue",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "If-None-Match",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputIssueDetailResponse"
                }
              }
            },
            "description": "Success",
            "headers": {
              "ETag": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "304": {
            "description": "Not Modified",
            "headers": {
              "ETag": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/CapGetIssueInvalidRequestErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/CapGetIssueNotFoundErrorResponse"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get Issue",
        "x-topogram-authorization": [
          {
            "ownership": "owner_or_admin",
            "ownershipField": "assignee_id"
          }
        ]
      },
      "patch": {
        "description": "Updates mutable issue fields",
        "operationId": "cap_update_issue",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "If-Match",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShapeInputUpdateIssueRequest"
              }
            }
          },
          "required": false
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputIssueDetailResponse"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/RuleOnlyActiveUsersMayBeAssignedIssuesError"
                    },
                    {
                      "$ref": "#/components/schemas/CapUpdateIssueInvalidRequestError"
                    }
                  ]
                }
              }
            },
            "description": "Error (400)"
          },
          "412": {
            "$ref": "#/components/responses/CapUpdateIssuePreconditionFailedErrorResponse"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Update Issue",
        "x-topogram-authorization": [
          {
            "ownership": "owner_or_admin",
            "ownershipField": "assignee_id",
            "permission": "issues.update"
          }
        ]
      }
    },
    "/issues/{id}/close": {
      "post": {
        "description": "Marks an issue as closed",
        "operationId": "cap_close_issue",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "If-Match",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "Idempotency-Key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShapeInputCloseIssueRequest"
              }
            }
          },
          "required": false
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputIssueDetailResponse"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "$ref": "#/components/responses/CapCloseIssueInvalidRequestErrorResponse"
          },
          "409": {
            "$ref": "#/components/responses/CapCloseIssueIdempotencyConflictErrorResponse"
          },
          "412": {
            "$ref": "#/components/responses/CapCloseIssuePreconditionFailedErrorResponse"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Close Issue",
        "x-topogram-authorization": [
          {
            "ownership": "owner_or_admin",
            "ownershipField": "assignee_id",
            "permission": "issues.close"
          }
        ]
      }
    }
  }
}
