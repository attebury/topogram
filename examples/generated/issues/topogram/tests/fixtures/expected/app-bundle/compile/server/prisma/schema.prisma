generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Board {
  created_at DateTime
  description String?
  id String @id
  name String @unique
  status String @default("active")
  issues Issue[] @relation("Issue_board_id_to_Board")
  @@map("boards")
}

model Issue {
  assignee_id String?
  assignee User? @relation("Issue_assignee_id_to_User", fields: [assignee_id], references: [id])
  board_id String
  board Board @relation("Issue_board_id_to_Board", fields: [board_id], references: [id])
  closed_at DateTime?
  created_at DateTime
  description String?
  id String @id
  priority String?
  status String @default("open")
  title String
  updated_at DateTime
  @@index([assignee_id, status])
  @@index([board_id, status])
  @@map("issues")
}

model User {
  created_at DateTime
  display_name String
  email String @unique
  id String @id
  is_active Boolean @default(true)
  issues Issue[] @relation("Issue_assignee_id_to_User")
  @@map("users")
}
