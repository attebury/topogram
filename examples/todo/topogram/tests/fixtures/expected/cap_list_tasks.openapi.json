{
  "components": {
    "responses": {
      "CapListTasksInvalidCursorErrorResponse": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CapListTasksInvalidCursorError"
            }
          }
        },
        "description": "Cap List Tasks Invalid Cursor (400)"
      },
      "CapListTasksInvalidLimitErrorResponse": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CapListTasksInvalidLimitError"
            }
          }
        },
        "description": "Cap List Tasks Invalid Limit (400)"
      },
      "CapListTasksInvalidRequestErrorResponse": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CapListTasksInvalidRequestError"
            }
          }
        },
        "description": "Cap List Tasks Invalid Request (400)"
      }
    },
    "schemas": {
      "CapListTasksInvalidCursorError": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ErrorResponse"
          },
          {
            "properties": {
              "code": {
                "const": "cap_list_tasks_invalid_cursor",
                "type": "string"
              }
            },
            "type": "object"
          }
        ],
        "title": "Cap List Tasks Invalid Cursor"
      },
      "CapListTasksInvalidLimitError": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ErrorResponse"
          },
          {
            "properties": {
              "code": {
                "const": "cap_list_tasks_invalid_limit",
                "type": "string"
              }
            },
            "type": "object"
          }
        ],
        "title": "Cap List Tasks Invalid Limit"
      },
      "CapListTasksInvalidRequestError": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ErrorResponse"
          },
          {
            "properties": {
              "code": {
                "const": "cap_list_tasks_invalid_request",
                "type": "string"
              }
            },
            "type": "object"
          }
        ],
        "title": "Cap List Tasks Invalid Request"
      },
      "ErrorResponse": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string"
          },
          "details": {
            "additionalProperties": true,
            "type": "object"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      },
      "ShapeOutputTaskDetailCursorPageResponse": {
        "additionalProperties": false,
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/ShapeOutputTaskDetailResponse"
            },
            "type": "array"
          },
          "next_cursor": {
            "type": "string"
          }
        },
        "required": [
          "items",
          "next_cursor"
        ],
        "type": "object"
      },
      "ShapeOutputTaskDetailResponse": {
        "$id": "topogram:shape:shape_output_task_detail",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "description": "Detailed task payload",
        "properties": {
          "completed_at": {
            "format": "date-time",
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "due_at": {
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "owner_id": {
            "format": "uuid",
            "type": "string"
          },
          "priority": {
            "default": "medium",
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "type": "string"
          },
          "project_id": {
            "format": "uuid",
            "type": "string"
          },
          "status": {
            "default": "draft",
            "enum": [
              "draft",
              "active",
              "completed",
              "archived"
            ],
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "status",
          "priority",
          "project_id",
          "created_at",
          "updated_at"
        ],
        "title": "Task Detail Output",
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "title": "Topogram API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/tasks": {
      "get": {
        "description": "Allows a user to list tasks",
        "operationId": "cap_list_tasks",
        "parameters": [
          {
            "in": "query",
            "name": "project_id",
            "required": false,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "owner_id",
            "required": false,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "status",
            "required": false,
            "schema": {
              "enum": [
                "draft",
                "active",
                "completed",
                "archived"
              ],
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "after",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 25,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputTaskDetailCursorPageResponse"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/CapListTasksInvalidRequestError"
                    },
                    {
                      "$ref": "#/components/schemas/CapListTasksInvalidCursorError"
                    },
                    {
                      "$ref": "#/components/schemas/CapListTasksInvalidLimitError"
                    }
                  ]
                }
              }
            },
            "description": "Error (400)"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List Tasks",
        "x-topogram-authorization": [
          {
            "permission": "tasks.read"
          }
        ]
      }
    }
  }
}
