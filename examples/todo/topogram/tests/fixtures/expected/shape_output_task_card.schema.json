{
  "$id": "topogram:shape:shape_output_task_card",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Compact task payload for cards and lists",
  "properties": {
    "dueAt": {
      "format": "date-time",
      "type": "string"
    },
    "ownerId": {
      "format": "uuid",
      "type": "string"
    },
    "priority": {
      "default": "medium",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "type": "string"
    },
    "status": {
      "default": "active",
      "enum": [
        "draft",
        "active",
        "completed",
        "archived"
      ],
      "type": "string"
    },
    "title": {
      "type": "string"
    }
  },
  "required": [
    "status",
    "priority",
    "ownerId"
  ],
  "title": "Task Card Output",
  "type": "object"
}
