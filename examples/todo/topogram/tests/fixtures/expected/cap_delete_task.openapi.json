{
  "components": {
    "responses": {
      "CapDeleteTaskInvalidRequestErrorResponse": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CapDeleteTaskInvalidRequestError"
            }
          }
        },
        "description": "Cap Delete Task Invalid Request (400)"
      },
      "CapDeleteTaskNotFoundErrorResponse": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CapDeleteTaskNotFoundError"
            }
          }
        },
        "description": "Cap Delete Task Not Found (404)"
      },
      "CapDeleteTaskPreconditionFailedErrorResponse": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CapDeleteTaskPreconditionFailedError"
            }
          }
        },
        "description": "Cap Delete Task Precondition Failed (412)"
      }
    },
    "schemas": {
      "CapDeleteTaskInvalidRequestError": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ErrorResponse"
          },
          {
            "properties": {
              "code": {
                "const": "cap_delete_task_invalid_request",
                "type": "string"
              }
            },
            "type": "object"
          }
        ],
        "title": "Cap Delete Task Invalid Request"
      },
      "CapDeleteTaskNotFoundError": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ErrorResponse"
          },
          {
            "properties": {
              "code": {
                "const": "cap_delete_task_not_found",
                "type": "string"
              }
            },
            "type": "object"
          }
        ],
        "title": "Cap Delete Task Not Found"
      },
      "CapDeleteTaskPreconditionFailedError": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ErrorResponse"
          },
          {
            "properties": {
              "code": {
                "const": "cap_delete_task_precondition_failed",
                "type": "string"
              }
            },
            "type": "object"
          }
        ],
        "title": "Cap Delete Task Precondition Failed"
      },
      "ErrorResponse": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string"
          },
          "details": {
            "additionalProperties": true,
            "type": "object"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      },
      "ShapeOutputTaskDetailResponse": {
        "$id": "topogram:shape:shape_output_task_detail",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "description": "Detailed task payload",
        "properties": {
          "completed_at": {
            "format": "date-time",
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "due_at": {
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "owner_id": {
            "format": "uuid",
            "type": "string"
          },
          "priority": {
            "default": "medium",
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "type": "string"
          },
          "project_id": {
            "format": "uuid",
            "type": "string"
          },
          "status": {
            "default": "draft",
            "enum": [
              "draft",
              "active",
              "completed",
              "archived"
            ],
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "status",
          "priority",
          "project_id",
          "created_at",
          "updated_at"
        ],
        "title": "Task Detail Output",
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "title": "Topogram API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/tasks/{id}": {
      "delete": {
        "description": "Allows a user to archive a task through the delete endpoint",
        "operationId": "cap_delete_task",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "If-Match",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputTaskDetailResponse"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "$ref": "#/components/responses/CapDeleteTaskInvalidRequestErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/CapDeleteTaskNotFoundErrorResponse"
          },
          "412": {
            "$ref": "#/components/responses/CapDeleteTaskPreconditionFailedErrorResponse"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Delete Task",
        "x-topogram-authorization": [
          {
            "permission": "tasks.delete",
            "role": "manager"
          }
        ]
      }
    }
  }
}
