{
  "components": {
    "responses": {
      "CapExportTasksInvalidRequestErrorResponse": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CapExportTasksInvalidRequestError"
            }
          }
        },
        "description": "Cap Export Tasks Invalid Request (400)"
      }
    },
    "schemas": {
      "CapExportTasksInvalidRequestError": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ErrorResponse"
          },
          {
            "properties": {
              "code": {
                "const": "cap_export_tasks_invalid_request",
                "type": "string"
              }
            },
            "type": "object"
          }
        ],
        "title": "Cap Export Tasks Invalid Request"
      },
      "ErrorResponse": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string"
          },
          "details": {
            "additionalProperties": true,
            "type": "object"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      },
      "ShapeInputExportTasksRequest": {
        "additionalProperties": false,
        "properties": {
          "callback_url": {
            "type": "string"
          },
          "owner_id": {
            "format": "uuid",
            "type": "string"
          },
          "project_id": {
            "format": "uuid",
            "type": "string"
          },
          "status": {
            "enum": [
              "draft",
              "active",
              "completed",
              "archived"
            ],
            "type": "string"
          }
        },
        "type": "object"
      },
      "ShapeOutputTaskExportCallbackResponse": {
        "$id": "topogram:shape:shape_output_task_export_callback",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "description": "Outbound webhook payload sent when a task export completes",
        "properties": {
          "completed_at": {
            "format": "date-time",
            "type": "string"
          },
          "download_url": {
            "type": "string"
          },
          "error_message": {
            "type": "string"
          },
          "job_id": {
            "format": "uuid",
            "type": "string"
          },
          "status": {
            "enum": [
              "accepted",
              "running",
              "completed",
              "failed",
              "expired"
            ],
            "type": "string"
          }
        },
        "required": [
          "job_id",
          "status"
        ],
        "title": "Task Export Callback",
        "type": "object"
      },
      "ShapeOutputTaskExportJobResponse": {
        "$id": "topogram:shape:shape_output_task_export_job",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "description": "Accepted job payload for long-running task exports",
        "properties": {
          "job_id": {
            "format": "uuid",
            "type": "string"
          },
          "status": {
            "default": "accepted",
            "type": "string"
          },
          "status_url": {
            "type": "string"
          },
          "submitted_at": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "job_id",
          "status",
          "status_url",
          "submitted_at"
        ],
        "title": "Task Export Job",
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "title": "Topogram API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/tasks/export": {
      "post": {
        "callbacks": {
          "export_completed": {
            "{$request.body#/callback_url}": {
              "post": {
                "requestBody": {
                  "content": {
                    "application/json": {
                      "schema": {
                        "$ref": "#/components/schemas/ShapeOutputTaskExportCallbackResponse"
                      }
                    }
                  },
                  "required": true
                },
                "responses": {
                  "202": {
                    "description": "Callback accepted"
                  }
                }
              }
            }
          }
        },
        "description": "Starts an asynchronous export job for tasks",
        "operationId": "cap_export_tasks",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShapeInputExportTasksRequest"
              }
            }
          },
          "required": false
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputTaskExportJobResponse"
                }
              }
            },
            "description": "Accepted",
            "headers": {
              "Location": {
                "schema": {
                  "type": "string"
                }
              },
              "Retry-After": {
                "schema": {
                  "type": "integer"
                }
              }
            },
            "links": {
              "cap_get_task_export_jobStatus": {
                "description": "Follow cap_get_task_export_job to monitor the async job",
                "operationId": "cap_get_task_export_job",
                "parameters": {
                  "job_id": "$response.body#/job_id"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/CapExportTasksInvalidRequestErrorResponse"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Export Tasks",
        "x-topogram-authorization": [
          {
            "permission": "tasks.export"
          }
        ]
      }
    }
  }
}
