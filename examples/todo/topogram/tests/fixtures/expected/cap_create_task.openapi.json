  "info": {
    "title": "Topogram API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/tasks": {
      "post": {
        "description": "Allows a user to create a new task",
        "operationId": "cap_create_task",
        "parameters": [
          {
            "in": "header",
            "name": "Idempotency-Key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShapeInputCreateTaskRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShapeOutputTaskDetailResponse"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/RuleOnlyActiveUsersMayOwnTasksError"
                    },
                    {
                      "$ref": "#/components/schemas/CapCreateTaskInvalidRequestError"
                    }
                  ]
                }
              }
            },
            "description": "Error (400)"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/RuleNoTaskCreationInArchivedProjectError"
                    },
                    {
                      "$ref": "#/components/schemas/CapCreateTaskIdempotencyConflictError"
                    }
                  ]
                }
              }
            },
            "description": "Error (409)"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Create Task",
        "x-topogram-authorization": [
          {
            "permission": "tasks.create"
          }
        ]
      }
    }
  }
}
