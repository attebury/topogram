# Environment profile
TOPOGRAM_ENVIRONMENT_PROFILE=local_docker

# Local stack ports
DB_PORT=5432
SERVER_PORT=3000
WEB_PORT=5173

# Local Postgres defaults
POSTGRES_DB=topogram_todo
POSTGRES_USER=${USER:-postgres}
POSTGRES_PASSWORD=postgres

# Local shell/runtime defaults
DATABASE_URL=postgresql://${POSTGRES_USER}@localhost:5432/topogram_todo?schema=public
DATABASE_ADMIN_URL=postgresql://${POSTGRES_USER}@localhost:5432/postgres
PUBLIC_TOPOGRAM_API_BASE_URL=http://localhost:3000
PUBLIC_TOPOGRAM_DEMO_USER_ID=11111111-1111-4111-8111-111111111111
TOPOGRAM_DEMO_USER_ID=11111111-1111-4111-8111-111111111111
PUBLIC_TOPOGRAM_DEMO_PRIMARY_ID=33333333-3333-4333-8333-333333333333
PUBLIC_TOPOGRAM_DEMO_CONTAINER_ID=22222222-2222-4222-8222-222222222222
TOPOGRAM_DEMO_PRIMARY_ID=33333333-3333-4333-8333-333333333333
TOPOGRAM_DEMO_CONTAINER_ID=22222222-2222-4222-8222-222222222222
TOPOGRAM_SEED_DEMO=true
