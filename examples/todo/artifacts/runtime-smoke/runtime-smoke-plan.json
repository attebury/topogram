{
  "type": "runtime_smoke_plan",
  "name": "Todo Runtime Smoke Plan",
  "projections": {
    "api": "proj_api",
    "ui": "proj_ui_web"
  },
  "env": {
    "apiBase": "TOPOGRAM_API_BASE_URL",
    "webBase": "TOPOGRAM_WEB_BASE_URL"
  },
  "checks": [
    {
      "id": "web_tasks_page",
      "type": "web_get",
      "path": "/tasks",
      "expectStatus": 200,
      "expectText": "Tasks"
    },
    {
      "id": "create_task",
      "type": "api_post",
      "path": "/tasks",
      "expectStatus": 201
    },
    {
      "id": "get_task",
      "type": "api_get",
      "path": "/tasks/:id",
      "expectStatus": 200
    },
    {
      "id": "list_tasks",
      "type": "api_get",
      "path": "/tasks",
      "expectStatus": 200
    }
  ]
}
