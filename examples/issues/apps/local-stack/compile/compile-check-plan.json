{
  "type": "compile_check_plan",
  "name": "Issues Generated Compile Checks",
  "projections": {
    "api": "proj_api",
    "ui": "proj_ui_web",
    "db": "proj_db_sqlite"
  },
  "checks": [
    {
      "id": "server_typecheck",
      "cwd": "server",
      "install": "npm install",
      "command": "npm run check"
    },
    {
      "id": "web_typecheck",
      "cwd": "web",
      "install": "npm install",
      "command": "npm run check"
    },
    {
      "id": "web_build",
      "cwd": "web",
      "install": "npm install",
      "command": "npm run build"
    }
  ]
}
