acceptance_criterion ac_cli_0_3_82_release_published {
  name "Cli 0 3 82 Release Published"
  description "Given widget vocabulary and widget migration planning changes are merged on main, when @topogram/cli 0.3.82 is prepared, published, smoke-tested, rolled to first-party consumers, and release evidence is refreshed, then strict release status is green for the CLI and first-party consumers."
  requirement req_widget_contract_migration_planning
  status approved
}
