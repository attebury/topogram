acceptance_criterion ac_cli_0_3_86_release_published {
  name "Cli 0 3 86 Release Published"
  description "Given package-backed extractor review UX is merged on main, when @topogram/cli 0.3.86 is prepared, published, smoke-tested, rolled to first-party consumers, and release evidence is refreshed, then strict release status is green for the CLI and extractor packages."
  requirement req_extractor_selection_ux
  status approved
}
