acceptance_criterion ac_cli_0_3_88_release_published {
  name "Cli 0 3 88 Release Published"
  description "Given the OpenAPI-code extractor source classification fix is merged on main, when @topogram/cli 0.3.88 is prepared, published, smoke-tested, rolled to first-party consumers, and release evidence is refreshed, then strict release status is green for the CLI and first-party packages."
  requirement req_import_docs_noise_filtering
  status approved
}
