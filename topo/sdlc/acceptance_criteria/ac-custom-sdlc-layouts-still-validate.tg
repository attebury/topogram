acceptance_criterion ac_custom_sdlc_layouts_still_validate {
  name "Custom SDLC Layouts Still Validate"
  description "Given a project uses an existing or custom SDLC folder layout, when Topogram validates the workspace, then the layout still passes because folder placement is a convention rather than a parser or validator requirement."
  requirement req_sdlc_records_use_dedicated_record_root
  status approved
}
