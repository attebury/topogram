acceptance_criterion ac_docs_reset_current_workflows {
  name "Docs Reset Current Workflows"
  description "Given a human or agent reads the live docs, when they need current-code guidance, then the docs provide workflow pages for greenfield generation, brownfield import, agent-first work, model concepts, CLI reference, DSL reference, template authoring, generator packs, and maintainer testing or release guidance."
  requirement req_docs_are_current_and_audience_oriented
  status approved
}
