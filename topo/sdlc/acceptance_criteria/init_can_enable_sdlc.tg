acceptance_criterion ac_init_can_enable_sdlc {
  name "Init Can Enable Sdlc"
  description "Given a directory without Topogram config, when `topogram init --adopt-sdlc` runs, then it creates the maintained workspace, writes topogram.sdlc-policy.json with adopted/enforced defaults, and scaffolds topo/sdlc folders."
  requirement req_init_maintained_workspace
  status approved
}
