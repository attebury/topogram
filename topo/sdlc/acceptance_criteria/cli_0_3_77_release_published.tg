acceptance_criterion ac_cli_0_3_77_release_published {
  name "Cli 0 3 77 Release Published"
  description "Given brownfield import noise filtering and CLI stdout fixes are merged on main, when @topogram/cli 0.3.77 is prepared, published, smoke-tested, and release evidence is refreshed, then strict release status is green for the CLI and first-party consumers."
  requirement req_stateful_actions_use_cli
  status approved
}
