acceptance_criterion ac_adversarial_residual_audit_cycle {
  name "Adversarial Residual Audit Cycle"
  description "Given an adversarial-review batch completes, when engineers record follow-up notes, then those notes tie risks to bounded tasks, verify extractor smoke plus SDLC discipline, and close or reopen deficits with fixture or test citations."
  requirement req_adversarial_residual_audit_cycle
  status approved
}
