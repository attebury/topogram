acceptance_criterion ac_cli_0_3_87_release_published {
  name "Cli 0 3 87 Release Published"
  description "Given bounded catalog and GitHub payload handling is merged on main, when @topogram/cli 0.3.87 is prepared, published, smoke-tested, rolled to first-party consumers, and release evidence is refreshed, then strict release status is green for the CLI and first-party packages."
  requirement req_bounded_catalog_and_github_fetch_payloads
  status approved
}
