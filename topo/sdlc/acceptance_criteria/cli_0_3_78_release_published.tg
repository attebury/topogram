  name "Cli 0 3 78 Release Published"
  description "Given import primary-source filtering fixes are merged on main, when @topogram/cli 0.3.78 is prepared, published, smoke-tested, and release evidence is refreshed, then strict release status is green for the CLI and first-party consumers."
  requirement req_stateful_actions_use_cli
  status approved
}
