acceptance_criterion ac_engine_dogfood_sdlc_records_are_grouped {
  name "Engine Dogfood SDLC Records Are Grouped"
  description "Given the engine dogfood topo stores SDLC records, when humans or agents inspect the workspace, then pitches, requirements, acceptance criteria, tasks, bugs, plans, decisions, and SDLC archives live under topo/sdlc while non-SDLC graph records remain at top level."
  requirement req_sdlc_records_use_dedicated_record_root
  status approved
}
