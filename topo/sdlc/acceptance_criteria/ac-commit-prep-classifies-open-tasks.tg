acceptance_criterion ac_commit_prep_classifies_open_tasks {
  name "Commit Prep Classifies Open Tasks"
  description "Given branch-touched task files including untracked new tasks, when `topogram sdlc prep commit` runs, then it reports open tasks, fails ambiguous unclaimed work, allows explicit follow-up/deferred/backlog disposition, and fails blocker disposition."
  requirement req_sdlc_commit_prep_surfaces_open_tasks
  status approved
}
