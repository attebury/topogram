acceptance_criterion ac_cli_0_3_79_release_published {
  name "Cli 0 3 79 Release Published"
  description "Given the command vocabulary cutover is merged on main, when @topogram/cli 0.3.79 is published, smoke-tested, rolled to first-party consumers, and release evidence is refreshed, then strict release status is green for the CLI and first-party consumers."
  requirement req_clear_command_vocabulary
  status approved
}
