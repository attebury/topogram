acceptance_criterion ac_sdlc_plans_are_optional {
  name "SDLC Plans Are Optional"
  description "Given a task or bug has no plan, when SDLC validation runs, then the record remains valid; given a plan exists, when validation runs, then Topogram enforces the plan and nested step shape."
  requirement req_sdlc_plans_track_implementation_steps
  status approved
}
