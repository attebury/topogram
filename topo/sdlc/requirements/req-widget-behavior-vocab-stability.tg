requirement req_widget_behavior_vocab_stability {
  name "Widget Behavior Vocabulary Stability"
  description "Topogram must expose one stable, engine-owned semantic widget behavior vocabulary for widget contracts, generator manifests, conformance reports, and agent packets before third-party template and generator authors depend on it."
  pitch pitch_ui_contract_maturity
  affects [cap_check_widget_contracts, cap_query_context]
  domain dom_sdlc_query_agent_context
  priority medium
  status satisfied
}
