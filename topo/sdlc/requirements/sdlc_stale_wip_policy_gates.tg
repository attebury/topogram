requirement req_sdlc_stale_wip_policy_gates {
  name "SDLC Stale Work And WIP Policy Gates"
  description "Topogram should let adopted projects optionally warn or fail when stale claimed or in-progress work and WIP pressure exceed policy thresholds."
  pitch pitch_stale_work_wip_gates
  affects [cap_manage_sdlc_records cap_run_engine_gates cap_query_context]
  respects_rules [rule_stateful_workflow_mutations_use_cli]
  domain dom_sdlc_query_agent_context
  priority high
  status satisfied
}
