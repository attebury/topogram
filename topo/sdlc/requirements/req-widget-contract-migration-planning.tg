requirement req_widget_contract_migration_planning {
  name "Widget Contract Migration Planning"
  description "Topogram must plan widget contract changes across affected projections so humans and agents understand which widget contracts, conformance reports, behavior wiring, and surface contracts need review after a baseline diff."
  pitch pitch_ui_contract_maturity
  affects [cap_check_widget_contracts, cap_generate_app_outputs, cap_query_context]
  domain dom_generator_runtime
  priority medium
  status approved
}
